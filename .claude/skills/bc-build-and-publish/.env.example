# BC environment configuration
# Copy this file to .env and fill in the values.
# Or run: .\.claude\skills\bc-build-and-publish\scripts\bc-login.ps1 -Environment "your-sandbox-name"
BC_TENANT_ID=
BC_ENVIRONMENT=
BC_REFRESH_TOKEN=

# E2E page scripting credentials (for bc-page-scripting skill)
# Dedicated test account with username/password (no interactive MFA)
# Account needs PAGESCRIPTING - PLAY permission set in BC
BC_E2E_USERNAME=
BC_E2E_PASSWORD=
